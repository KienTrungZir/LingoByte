# ========================
# LingoByte - .gitignore
# ========================

# ---- Python / Backend ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environment
venv/
.venv/
env/

# Environment variables
.env
.env.local
.env.*.local

# ---- Node.js / Frontend ----
node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Database ----
*.mdf
*.ldf
*.bak

# ---- Scratch / Temp ----
scratch/
*.tmp
*.temp

# ---- OS ----
.DS_Store
ehthumbs.db

# ---- Misc ----
*.pkl
*.pickle
.agents/
